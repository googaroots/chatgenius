# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server
PORT=3000
NODE_ENV=development

# ChromaDB (in-process, no Docker needed)
CHROMA_PERSIST_PATH=./chroma_data
CHROMA_COLLECTION=chatgenius_kb

# Human Handoff
HANDOFF_WEBHOOK_URL=https://your-helpdesk.example.com/api/tickets
HANDOFF_API_KEY=your_helpdesk_api_key_here

# CRM Integration
CRM_WEBHOOK_URL=https://your-crm.example.com/api/events
CRM_API_KEY=your_crm_api_key_here

# Analytics (optional: persist to external DB)
ANALYTICS_RETENTION_DAYS=90
